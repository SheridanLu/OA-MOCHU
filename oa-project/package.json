{
  "name": "engineering-oa-system",
  "version": "1.0.0",
  "description": "工程项目管理OA系统",
  "scripts": {
    "server": "node src/backend/index.js",
    "client": "cd src/frontend && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "db:init": "node src/backend/init-db.js",
    "init": "./scripts/init.sh",
    "test": "jest src/backend/tests/api.test.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.0",
    "compression": "^1.8.1",
    "concurrently": "^8.2.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "supertest": "^7.2.2"
  }
}
